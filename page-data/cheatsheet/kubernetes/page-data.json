{"componentChunkName":"component---src-components-markdown-template-js","path":"/cheatsheet/kubernetes","result":{"data":{"markdownRemark":{"html":"<ul>\n<li><a href=\"#mount-secret-file\">Mount secret file</a></li>\n<li><a href=\"#mount-ssl\">Mount SSL</a></li>\n</ul>\n<h3>Mount secret file</h3>\n<deckgo-highlight-code bash  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">$ kubectl create secret generic {secret name} --from-file={file path}</code>\n        </deckgo-highlight-code>\n<h3>Mount SSL</h3>\n<deckgo-highlight-code bash  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">$ kubectl create secret tls {secret name} --key {key file path} --cert {cert file path}</code>\n        </deckgo-highlight-code>","frontmatter":{"date":"May 04, 2019","slug":"/cheatsheet/kubernetes","title":"Kubernetes"}}},"pageContext":{"slug":"/cheatsheet/kubernetes"}},"staticQueryHashes":["3568358583"]}