{"componentChunkName":"component---src-components-markdown-template-js","path":"/cheatsheet/mysql","result":{"data":{"markdownRemark":{"html":"<ul>\n<li><a href=\"#add-column\">Add column</a></li>\n<li><a href=\"#connecting-to-the-mysql\">Connecting to the MySQL</a></li>\n</ul>\n<h3>Add column</h3>\n<p>Adding a new column in the existing table.</p>\n<deckgo-highlight-code sql  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">ALTER TABLE table_name ADD COLUMN column_name VARCHAR(200) NOT NULL;</code>\n        </deckgo-highlight-code>\n<h3>Connecting to the MySQL</h3>\n<p>Connecting to the MySQL using command.</p>\n<deckgo-highlight-code console  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">$ mysql -h 123.456.7.89 -P 3306 -u root -p</code>\n        </deckgo-highlight-code>","frontmatter":{"date":"May 04, 2019","slug":"/cheatsheet/mysql","title":"MySQL"}}},"pageContext":{"slug":"/cheatsheet/mysql"}},"staticQueryHashes":["3568358583"]}