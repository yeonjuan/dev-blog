{"componentChunkName":"component---src-components-markdown-template-js","path":"/cheatsheet/argo","result":{"data":{"markdownRemark":{"html":"<ul>\n<li><a href=\"#create-cron-workflow\">Create cron workflow</a></li>\n<li><a href=\"#submit-workflow\">Submit workflow</a></li>\n</ul>\n<h3>Create cron workflow</h3>\n<p>Create cron workflow with argo cli.</p>\n<deckgo-highlight-code bash  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">$ argo cron create {cron-workflow.yaml}</code>\n        </deckgo-highlight-code>\n<h3>Submit workflow</h3>\n<p>Submit workflow with argo cli.</p>\n<deckgo-highlight-code bash  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">$ argo submit {workflow.yaml}</code>\n        </deckgo-highlight-code>\n<h3>Access the argo workflow ui</h3>\n<deckgo-highlight-code bash  terminal=\"carbon\" theme=\"base16-light\"  highlight-lines=\"\">\n          <code slot=\"code\">$ kubectl -n argo port-forward svc/argo-server 2746:2746</code>\n        </deckgo-highlight-code>","frontmatter":{"date":"May 04, 2019","slug":"/cheatsheet/argo","title":"Argo"}}},"pageContext":{"slug":"/cheatsheet/argo"}},"staticQueryHashes":["3568358583"]}